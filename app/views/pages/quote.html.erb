<% content_for :title, "Get a Free Quote | Jack SaaS" %>

<%# Hero Section %>
<section class="py-12 md:py-16 bg-gradient-to-br from-blue-600 to-blue-700">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-2xl mx-auto">
      <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold text-white mb-4">Get a Free Quote</h1>
      <p class="text-lg text-blue-100">Tell us about your project and we'll get back to you within 24 hours with a detailed proposal.</p>
    </div>
  </div>
</section>

<%# Form Section %>
<section class="py-12 md:py-16 bg-slate-50">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="bg-white rounded-2xl shadow-lg border border-slate-200 overflow-hidden">
      <%# Form Header %>
      <div class="px-6 md:px-8 py-6 bg-slate-50 border-b border-slate-200">
        <h2 class="text-xl font-semibold text-slate-900">Project Details</h2>
        <p class="text-sm text-slate-600 mt-1">Fill out the form below and we'll get back to you shortly.</p>
      </div>

      <%# Form Body %>
      <div class="p-6 md:p-8">
        <form action="/api/quote" method="post" class="space-y-6" data-controller="form" data-turbo="false">
          <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
          
          <%# Honeypot field %>
          <input type="text" name="website_url" class="hidden" tabindex="-1" autocomplete="off">

          <%# Section: Contact Information %>
          <div class="space-y-5">
            <h3 class="text-sm font-semibold text-slate-900 uppercase tracking-wider border-b border-slate-200 pb-2">Contact Information</h3>
            
            <div class="grid md:grid-cols-2 gap-5">
              <%# Name Field %>
              <div class="space-y-2">
                <label for="name" class="block text-sm font-medium text-slate-900">
                  Full Name <span class="text-red-500">*</span>
                </label>
                <input 
                  type="text" 
                  id="name" 
                  name="name" 
                  required 
                  class="w-full px-4 py-3 rounded-lg border border-slate-300 text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all"
                  placeholder="John Doe"
                  data-form-target="input"
                  data-action="blur->form#validateField"
                >
                <p class="hidden text-sm text-red-600" data-form-target="error" data-field="name">Please enter your full name</p>
              </div>

              <%# Email Field %>
              <div class="space-y-2">
                <label for="email" class="block text-sm font-medium text-slate-900">
                  Email Address <span class="text-red-500">*</span>
                </label>
                <input 
                  type="email" 
                  id="email" 
                  name="email" 
                  required 
                  class="w-full px-4 py-3 rounded-lg border border-slate-300 text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all"
                  placeholder="john@company.com"
                  data-form-target="input"
                  data-action="blur->form#validateField"
                >
                <p class="hidden text-sm text-red-600" data-form-target="error" data-field="email">Please enter a valid email address</p>
              </div>
            </div>

            <div class="grid md:grid-cols-2 gap-5">
              <%# Company Field %>
              <div class="space-y-2">
                <label for="company" class="block text-sm font-medium text-slate-900">
                  Company Name <span class="text-slate-400 font-normal">(optional)</span>
                </label>
                <input 
                  type="text" 
                  id="company" 
                  name="company" 
                  class="w-full px-4 py-3 rounded-lg border border-slate-300 text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all"
                  placeholder="Acme Inc."
                >
              </div>

              <%# Website Field %>
              <div class="space-y-2">
                <label for="website" class="block text-sm font-medium text-slate-900">
                  Website <span class="text-slate-400 font-normal">(optional)</span>
                </label>
                <div class="relative">
                  <span class="absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 text-sm">https://</span>
                  <input 
                    type="text" 
                    id="website" 
                    name="website" 
                    class="w-full pl-16 pr-4 py-3 rounded-lg border border-slate-300 text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all"
                    placeholder="www.company.com"
                  >
                </div>
              </div>
            </div>
          </div>

          <%# Section: Project Details %>
          <div class="space-y-5 pt-4">
            <h3 class="text-sm font-semibold text-slate-900 uppercase tracking-wider border-b border-slate-200 pb-2">Project Details</h3>
            
            <%# Project Description %>
            <div class="space-y-2">
              <label for="description" class="block text-sm font-medium text-slate-900">
                Tell us about your project <span class="text-red-500">*</span>
              </label>
              <textarea 
                id="description" 
                name="description" 
                rows="5" 
                required 
                class="w-full px-4 py-3 rounded-lg border border-slate-300 text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all resize-y"
                placeholder="Describe your business, the workflows you want to automate, current challenges, and your goals..."
                data-form-target="input"
                data-action="blur->form#validateField input->form#updateCharCount"
              ></textarea>
              <div class="flex justify-between text-xs text-slate-500">
                <span>Minimum 50 characters recommended</span>
                <span data-form-target="charCount">0 characters</span>
              </div>
              <p class="hidden text-sm text-red-600" data-form-target="error" data-field="description">Please describe your project</p>
            </div>

            <%# Budget & Timeline %>
            <div class="grid md:grid-cols-2 gap-5">
              <div class="space-y-2">
                <label for="budget" class="block text-sm font-medium text-slate-900">
                  Estimated Budget <span class="text-slate-400 font-normal">(optional)</span>
                </label>
                <div class="relative">
                  <select 
                    id="budget" 
                    name="budget" 
                    class="w-full px-4 py-3 rounded-lg border border-slate-300 text-slate-900 bg-white focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all appearance-none cursor-pointer"
                  >
                    <option value="">Select a range...</option>
                    <option value="10k-25k">$10,000 - $25,000</option>
                    <option value="25k-50k">$25,000 - $50,000</option>
                    <option value="50k-100k">$50,000 - $100,000</option>
                    <option value="100k+">$100,000+</option>
                    <option value="not-sure">Not sure yet</option>
                  </select>
                  <div class="absolute right-4 top-1/2 -translate-y-1/2 pointer-events-none">
                    <svg class="w-5 h-5 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                    </svg>
                  </div>
                </div>
              </div>

              <div class="space-y-2">
                <label for="timeline" class="block text-sm font-medium text-slate-900">
                  Desired Timeline <span class="text-slate-400 font-normal">(optional)</span>
                </label>
                <div class="relative">
                  <select 
                    id="timeline" 
                    name="timeline" 
                    class="w-full px-4 py-3 rounded-lg border border-slate-300 text-slate-900 bg-white focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all appearance-none cursor-pointer"
                  >
                    <option value="">Select a timeline...</option>
                    <option value="asap">ASAP</option>
                    <option value="1-2-months">1-2 months</option>
                    <option value="3-6-months">3-6 months</option>
                    <option value="6-months+">6+ months</option>
                    <option value="not-sure">Not sure yet</option>
                  </select>
                  <div class="absolute right-4 top-1/2 -translate-y-1/2 pointer-events-none">
                    <svg class="w-5 h-5 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                    </svg>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <%# Submit Section %>
          <div class="pt-6 border-t border-slate-200 space-y-4">
            <button 
              type="submit" 
              class="w-full sm:w-auto px-8 py-4 bg-blue-600 text-white font-semibold text-lg rounded-lg hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 transition-all shadow-md hover:shadow-lg flex items-center justify-center gap-2"
              data-form-target="submit"
            >
              <span>Submit Quote Request</span>
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
              </svg>
            </button>
            
            <p class="text-sm text-slate-500 flex items-center gap-2">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
              </svg>
              We respect your privacy. Your information will never be shared with third parties.
            </p>
          </div>
        </form>
      </div>
    </div>

    <%# Alternative Contact %>
    <div class="mt-8 text-center">
      <p class="text-slate-600 mb-4">Prefer to talk directly?</p>
      <a href="mailto:contact@jacksaas.com" class="inline-flex items-center gap-2 text-blue-600 font-medium hover:text-blue-700 transition-colors">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
        </svg>
        contact@jacksaas.com
      </a>
    </div>
  </div>
</section>
